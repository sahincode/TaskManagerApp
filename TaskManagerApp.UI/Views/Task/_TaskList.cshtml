@using TaskManagerApp.Application.Utilities
@model IEnumerable<TaskManagerApp.Domain.Entities.TaskItem>

<table class="table table-hover table-bordered align-middle text-center">
    <thead class="table-dark">
    <tr>
        <th style="width: 25%;">Title</th>
        <th style="width: 15%;">Priority</th>
        <th style="width: 25%;">Deadline</th>
        <th style="width: 20%;">Status</th>
        <th style="width: 15%;">Actions</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td class="text-start fw-semibold">@item.Title</td>

            <td>
                <span class="badge bg-secondary">
                    @item.Priority
                </span>
            </td>

            <td>
                @(item.Deadline.HasValue 
                    ? item.Deadline.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") 
                    : "-")
            </td>

            <td>
                <span class="badge bg-info text-dark">
                    @TaskStatusHelper.GetStatus(item)
                </span>
            </td>

            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                    Details
                </a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                    Edit
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>