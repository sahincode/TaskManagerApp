@using TaskManagerApp.Domain.Enums
@model TaskManagerApp.Domain.Entities.TaskItem

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create Task</h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Title -->
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter task title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <!-- Priority -->
                <div class="mb-3">
                    <label class="form-label">Priority</label>
                    <select asp-for="Priority" class="form-select"
                            asp-items="Html.GetEnumSelectList<Priority>()">
                    </select>
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>

                <!-- Deadline -->
                <div class="mb-3">
                    <label class="form-label">Deadline</label>
                    <input asp-for="Deadline" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Deadline" class="text-danger"></span>
                </div>

                <!-- IsCompleted -->
                <div class="form-check mb-3">
                    <input asp-for="IsCompleted" class="form-check-input" type="checkbox" />
                    <label class="form-check-label">Completed</label>
                    <span asp-validation-for="IsCompleted" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>

            </form>
        </div>
    </div>
</div>