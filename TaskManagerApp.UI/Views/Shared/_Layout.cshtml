<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TaskManagerApp.UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/TaskManagerApp.UI.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar bg-white shadow-sm border-bottom py-3">
        <div class="container-fluid justify-content-center">

            <span class="navbar-brand mb-0 h1 fw-bold text-primary"
                  style="
                    font-size: 1.6rem;
                    letter-spacing: 1px;
                    text-shadow: 0 2px 6px rgba(0,0,0,0.1);
                  ">
                Task Manager App
            </span>

        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>